# AIWorkHelper 环境变量配置模板
# 复制此文件为 .env.development / .env.production / .env.test

# ========== 环境配置 ==========
ENVIRONMENT=development

# ========== 应用基础配置 ==========
APP_NAME=AIWorkHelper
APP_VERSION=0.1.0
API_PREFIX=/api/v1
DEBUG=true

# ========== 服务器与 HTTP 配置 ==========
HOST=0.0.0.0
PORT=8888
HTTP_TIMEOUT=30

# ========== CORS 配置 ==========
ALLOW_ORIGINS=["http://localhost:3000","http://localhost:5173"]
ALLOW_CREDENTIALS=true
ALLOW_METHODS=["*"]
ALLOW_HEADERS=["*"]

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30

# ========== 数据库配置 ==========
# 本地开发（无认证）
MONGODB_URI=mongodb://localhost:27017
# Docker 环境（带认证）
# MONGODB_URI=mongodb://admin:admin123@localhost:27017/aiworkhelper?authSource=admin
MONGODB_DATABASE=aiworkhelper
REDIS_URI=redis://localhost:6379/0

# ========== JWT 配置 ==========
# 生产环境请使用强密钥并妥善保管
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_EXPIRE_DAYS=30